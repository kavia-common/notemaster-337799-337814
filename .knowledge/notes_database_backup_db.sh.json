{"is_source_file": true, "format": "bash", "description": "A shell script for automating backups of various databases (SQLite, PostgreSQL, MySQL, MongoDB). It detects which database is active and performs the appropriate backup commands.", "external_files": ["/usr/lib/postgresql/", "/var/run/mysqld/mysqld.sock"], "external_methods": ["pg_isready", "ls", "mysqladmin", "mysql", "mysqldump", "mongosh", "mongodump"], "published": [], "classes": [], "methods": [], "calls": ["ls /usr/lib/postgresql/", "sudo -u postgres ${PG_BIN}/pg_isready", "cp \"${DB_NAME}\" \"database_backup.db\"", "mongosh --port ${DB_PORT} --eval \"db.adminCommand('ping')\"", "mongodump --port ${DB_PORT} --db ${DB_NAME} --archive=database_backup.archive --quiet", "mysqladmin ping -h localhost -P ${DB_PORT} --silent", "sudo mysqladmin ping --socket=/var/run/mysqld/mysqld.sock --silent", "mysql -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD} -e \"SELECT 1\"", "mysqldump -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD} --databases ${DB_NAME} --add-drop-database --routines --triggers --single-transaction", "mysql -h localhost -P ${DB_PORT} -u root -p${DB_PASSWORD} -e \"SELECT 1\"", "sudo mysqldump --socket=/var/run/mysqld/mysqld.sock -u root -p${DB_PASSWORD} --databases ${DB_NAME} --add-drop-database --routines --triggers --single-transaction", "sudo mysql --socket=/var/run/mysqld/mysqld.sock -u root -e \"SELECT 1\"", "mongosh --port ${DB_PORT} --eval \"db.adminCommand('ping')\"", "mongodump --port ${DB_PORT} --db ${DB_NAME} --archive=database_backup.archive --quiet"], "search-terms": ["backup_db.sh", "database backup script", "PostgreSQL", "MySQL", "MongoDB", "SQLite", "database detection", "shell backup"], "state": 2, "file_id": 6, "knowledge_revision": 14, "git_revision": "a361a7c43476415f99bc78065906e2f8123de35a", "hash": "7af9aa35fa4940f934d83f6e2621b732", "format-version": 4, "code-base-name": "notes_database", "filename": "notes_database/backup_db.sh", "revision_history": [{"14"